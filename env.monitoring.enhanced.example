# Enhanced Monitoring & Analytics Configuration
# Copy this file to .env.local and customize the values

# =============================================================================
# CORE MONITORING FEATURES
# =============================================================================

# Enable/disable the entire monitoring system
MONITORING_ENABLED=true

# Data sampling rate (0.0 to 1.0, where 1.0 = 100% of data)
MONITORING_SAMPLE_RATE=1.0

# Data retention period in days
MONITORING_RETENTION_DAYS=90

# =============================================================================
# PRIVACY & COMPLIANCE
# =============================================================================

# Enable privacy mode (anonymizes user data)
MONITORING_PRIVACY_MODE=false

# Enable geolocation tracking
MONITORING_GEOLOCATION=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable performance tracking
MONITORING_PERFORMANCE=true

# Enable error tracking and logging
MONITORING_ERRORS=true

# Enable user analytics and behavior tracking
MONITORING_USER_ANALYTICS=true

# Enable real-time updates and WebSocket connections
MONITORING_REALTIME=true

# Enable system alerting
MONITORING_ALERTING=true

# Enable data export functionality
MONITORING_DATA_EXPORT=true

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================

# WebSocket heartbeat interval in milliseconds
MONITORING_WS_HEARTBEAT=30000

# Maximum number of concurrent WebSocket connections
MONITORING_WS_MAX_CONNECTIONS=1000

# WebSocket connection timeout in milliseconds
MONITORING_WS_TIMEOUT=30000

# Enable WebSocket compression
MONITORING_WS_COMPRESSION=true

# =============================================================================
# MACHINE LEARNING & INSIGHTS
# =============================================================================

# Enable machine learning insights
MONITORING_ML_ENABLED=true

# ML models to use (comma-separated)
MONITORING_ML_MODELS=user_behavior,performance_anomaly,conversion_prediction,trend_analysis

# Confidence threshold for ML insights (0.0 to 1.0)
MONITORING_ML_CONFIDENCE=0.7

# ML model update interval in milliseconds
MONITORING_ML_UPDATE_INTERVAL=3600000

# Training data retention period in days
MONITORING_ML_TRAINING_RETENTION=365

# =============================================================================
# PERFORMANCE MONITORING
# =============================================================================

# Enable Core Web Vitals tracking
MONITORING_CORE_WEB_VITALS=true

# Performance metrics collection interval in milliseconds
MONITORING_PERFORMANCE_INTERVAL=60000

# Enable resource timing API
MONITORING_RESOURCE_TIMING=true

# Enable long task monitoring
MONITORING_LONG_TASKS=true

# =============================================================================
# SYSTEM MONITORING
# =============================================================================

# System metrics collection interval in milliseconds
MONITORING_SYSTEM_INTERVAL=30000

# Enable CPU monitoring
MONITORING_CPU_MONITORING=true

# Enable memory monitoring
MONITORING_MEMORY_MONITORING=true

# Enable disk I/O monitoring
MONITORING_DISK_MONITORING=true

# Enable network monitoring
MONITORING_NETWORK_MONITORING=true

# Enable process monitoring
MONITORING_PROCESS_MONITORING=true

# =============================================================================
# USER ANALYTICS
# =============================================================================

# User session timeout in milliseconds
MONITORING_SESSION_TIMEOUT=1800000

# Enable user journey tracking
MONITORING_USER_JOURNEY=true

# Enable conversion funnel tracking
MONITORING_CONVERSION_FUNNEL=true

# Enable A/B testing support
MONITORING_AB_TESTING=true

# =============================================================================
# ALERTING & NOTIFICATIONS
# =============================================================================

# Alert severity levels (comma-separated)
MONITORING_ALERT_LEVELS=info,warning,error,critical

# Enable email notifications
MONITORING_EMAIL_ALERTS=false

# Enable Slack notifications
MONITORING_SLACK_ALERTS=false

# Enable webhook notifications
MONITORING_WEBHOOK_ALERTS=false

# =============================================================================
# DATA STORAGE & CACHING
# =============================================================================

# Enable data caching
MONITORING_CACHE_ENABLED=true

# Cache TTL in milliseconds
MONITORING_CACHE_TTL=300000

# Enable data compression
MONITORING_COMPRESSION=true

# Database connection pool size
MONITORING_DB_POOL_SIZE=10

# =============================================================================
# SECURITY & ACCESS CONTROL
# =============================================================================

# Enable API rate limiting
MONITORING_RATE_LIMITING=true

# Rate limit requests per minute
MONITORING_RATE_LIMIT_PER_MINUTE=1000

# Enable API authentication
MONITORING_API_AUTH=true

# API key for external access
MONITORING_API_KEY=your-secure-api-key-here

# =============================================================================
# INTEGRATIONS
# =============================================================================

# Enable Prometheus metrics export
MONITORING_PROMETHEUS_EXPORT=true

# Enable Grafana integration
MONITORING_GRAFANA_INTEGRATION=false

# Enable Slack integration
MONITORING_SLACK_INTEGRATION=false

# Enable email integration
MONITORING_EMAIL_INTEGRATION=false

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Enable debug logging
MONITORING_DEBUG_LOGGING=false

# Log level (error, warn, info, debug)
MONITORING_LOG_LEVEL=info

# Enable performance profiling
MONITORING_PERFORMANCE_PROFILING=false

# Enable metrics validation
MONITORING_METRICS_VALIDATION=true

# =============================================================================
# THRESHOLDS & LIMITS
# =============================================================================

# CPU usage warning threshold (percentage)
MONITORING_CPU_WARNING_THRESHOLD=80

# CPU usage critical threshold (percentage)
MONITORING_CPU_CRITICAL_THRESHOLD=90

# Memory usage warning threshold (percentage)
MONITORING_MEMORY_WARNING_THRESHOLD=80

# Memory usage critical threshold (percentage)
MONITORING_MEMORY_CRITICAL_THRESHOLD=90

# Disk usage warning threshold (percentage)
MONITORING_DISK_WARNING_THRESHOLD=80

# Disk usage critical threshold (percentage)
MONITORING_DISK_CRITICAL_THRESHOLD=90

# Response time warning threshold (milliseconds)
MONITORING_RESPONSE_TIME_WARNING=1000

# Response time critical threshold (milliseconds)
MONITORING_RESPONSE_TIME_CRITICAL=3000

# =============================================================================
# REPORTING & EXPORT
# =============================================================================

# Enable automated reporting
MONITORING_AUTO_REPORTING=true

# Report generation interval in milliseconds
MONITORING_REPORT_INTERVAL=86400000

# Enable CSV export
MONITORING_CSV_EXPORT=true

# Enable JSON export
MONITORING_JSON_EXPORT=true

# Enable PDF export
MONITORING_PDF_EXPORT=false

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Enable automatic backups
MONITORING_AUTO_BACKUP=true

# Backup interval in milliseconds
MONITORING_BACKUP_INTERVAL=86400000

# Backup retention period in days
MONITORING_BACKUP_RETENTION=30

# Enable backup compression
MONITORING_BACKUP_COMPRESSION=true

# =============================================================================
# CUSTOMIZATION
# =============================================================================

# Custom dashboard refresh interval in milliseconds
MONITORING_DASHBOARD_REFRESH=30000

# Enable custom metrics
MONITORING_CUSTOM_METRICS=true

# Enable custom alerts
MONITORING_CUSTOM_ALERTS=true

# Enable custom dashboards
MONITORING_CUSTOM_DASHBOARDS=true

# =============================================================================
# LEGACY COMPATIBILITY
# =============================================================================

# Enable legacy API endpoints
MONITORING_LEGACY_API=true

# Enable legacy dashboard components
MONITORING_LEGACY_DASHBOARDS=false

# Enable legacy metrics collection
MONITORING_LEGACY_METRICS=false
